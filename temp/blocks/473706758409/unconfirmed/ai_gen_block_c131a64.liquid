{% doc %}
  @prompt
    Hier die Beschreibung für den Freelancer:
    
    Sektion: Testimonial Slider / Kundenbewertungen
    Layout: Volle Breite, heller Hintergrund (Gradient von weiß zu hellgrau). 3 Slides mit Pfeil-Navigation links/rechts und Dot-Indikatoren unten mittig.
    Slide-Aufbau (gleiche Struktur für alle 3):
    
    Links: Bild einer Person (ca. 40% Breite, leicht abgeschnitten unten)
    Rechts: Text-Block vertikal zentriert
    
    Rechter Content:
    
    5 Sterne (★★★★★) als Text/Icon, schwarz, groß
    Label "Kundenbewertungen:" darunter, normal weight
    2 Zitate in Anführungszeichen, bold, große Schrift (~22–24px), zeilengetrennt
    
    3 Slides Inhalt:
    Slide 1 (aktuell sichtbar):
    
    Bild: Ärztin/Pflegerin in türkisem Kittel
    Zitat 1: "Sooo schnelle und unkomplizierte Lieferung – Vielen Dank für den super Service"
    Zitat 2: "Günstige Preise, schnelle Lieferung, sicher verpackt – also perfekt."
    
    Slide 2 & 3: gleiche Struktur, andere Person + andere Zitate
    Navigation:
    
    Pfeile < > links/rechts außen, dezent
    3 Dots unten mittig (aktiver Dot etwas größer/dunkler)
    
    Shopify Hinweis: Als Section mit blocks aufbauen – jeder Slide = 1 Block mit settings für Bild, Zitat 1, Zitat 2. So kann der Shopify-Admin die Slides flexibel befüllen.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonial-slider-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: linear-gradient(180deg, #ffffff 0%, #f5f5f5 100%);
    padding: 60px 0;
    position: relative;
  }

  .ai-testimonial-slider__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
  }

  .ai-testimonial-slider__slide-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 40% 60%;
    gap: 40px;
    align-items: center;
  }

  .ai-testimonial-slider__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 500px;
    overflow: hidden;
    border-radius: 8px;
  }

  .ai-testimonial-slider__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .ai-testimonial-slider__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-testimonial-slider__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-testimonial-slider__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 20px 0;
  }

  .ai-testimonial-slider__stars-{{ ai_gen_id }} {
    font-size: 32px;
    color: #000000;
    line-height: 1;
  }

  .ai-testimonial-slider__label-{{ ai_gen_id }} {
    font-size: 16px;
    color: #1d2e40;
    font-weight: 400;
  }

  .ai-testimonial-slider__quotes-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-testimonial-slider__quote-{{ ai_gen_id }} {
    font-size: 22px;
    font-weight: 700;
    color: #1d2e40;
    line-height: 1.4;
  }

  @media screen and (max-width: 749px) {
    .ai-testimonial-slider__slide-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .ai-testimonial-slider__image-wrapper-{{ ai_gen_id }} {
      height: 350px;
    }

    .ai-testimonial-slider__quote-{{ ai_gen_id }} {
      font-size: 18px;
    }

    .ai-testimonial-slider__stars-{{ ai_gen_id }} {
      font-size: 28px;
    }
  }
{% endstyle %}

<div class="ai-testimonial-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-testimonial-slider__container-{{ ai_gen_id }}">
    <div class="ai-testimonial-slider__slide-{{ ai_gen_id }}">
      <div class="ai-testimonial-slider__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 800 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-testimonial-slider__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-testimonial-slider__image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-testimonial-slider__content-{{ ai_gen_id }}">
        <div class="ai-testimonial-slider__stars-{{ ai_gen_id }}">★★★★★</div>
        <div class="ai-testimonial-slider__label-{{ ai_gen_id }}">Kundenbewertungen:</div>
        <div class="ai-testimonial-slider__quotes-{{ ai_gen_id }}">
          {% if block.settings.quote_1 != blank %}
            <div class="ai-testimonial-slider__quote-{{ ai_gen_id }}">"{{ block.settings.quote_1 }}"</div>
          {% endif %}
          {% if block.settings.quote_2 != blank %}
            <div class="ai-testimonial-slider__quote-{{ ai_gen_id }}">"{{ block.settings.quote_2 }}"</div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Testimonial",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bild"
    },
    {
      "type": "textarea",
      "id": "quote_1",
      "label": "Zitat 1",
      "default": "Sooo schnelle und unkomplizierte Lieferung – Vielen Dank für den super Service"
    },
    {
      "type": "textarea",
      "id": "quote_2",
      "label": "Zitat 2",
      "default": "Günstige Preise, schnelle Lieferung, sicher verpackt – also perfekt."
    }
  ],
  "presets": [
    {
      "name": "Testimonial"
    }
  ]
}
{% endschema %}
