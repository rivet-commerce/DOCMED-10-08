{% doc %}
  @prompt
    ich brauche eine section in der der kunde sich durch ein paar beliebete katergeoien klicken kann bzw diese ihm präsentiren werden 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-category-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-category-grid__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-category-grid__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-category-grid__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin-top: 8px;
  }

  .ai-category-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-category-card-{{ ai_gen_id }} {
    position: relative;
    display: block;
    text-decoration: none;
    overflow: hidden;
    border-radius: {{ block.settings.card_border_radius }}px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
  }

  .ai-category-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
  }

  .ai-category-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-category-card__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-category-card-{{ ai_gen_id }}:hover .ai-category-card__image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-category-card__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-category-card__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-category-card__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,{{ block.settings.overlay_opacity }}) 100%);
    display: flex;
    align-items: flex-end;
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-category-card__content-{{ ai_gen_id }} {
    width: 100%;
    color: {{ block.settings.text_color }};
  }

  .ai-category-card__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 600;
    margin: 0 0 4px 0;
    color: {{ block.settings.text_color }};
  }

  .ai-category-card__count-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_count_size }}px;
    opacity: 0.9;
    color: {{ block.settings.text_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-category-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }

    .ai-category-grid__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-category-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-category-grid__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-category-card__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.card_title_size }}px * 0.9);
    }
  }
{% endstyle %}

<category-grid-{{ ai_gen_id }}
  class="ai-category-grid-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank or block.settings.subheading != blank %}
    <div class="ai-category-grid__header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-category-grid__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <div class="ai-category-grid__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-category-grid__container-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign collection_key = 'collection_' | append: i
        assign collection = block.settings[collection_key]
      %}

      {% if collection != blank %}
        <a
          href="{{ collection.url }}"
          class="ai-category-card-{{ ai_gen_id }}"
          aria-label="{{ collection.title }}"
        >
          <div class="ai-category-card__image-wrapper-{{ ai_gen_id }}">
            {% if collection.featured_image %}
              <img
                src="{{ collection.featured_image | image_url: width: 600 }}"
                alt="{{ collection.featured_image.alt | escape }}"
                loading="lazy"
                width="600"
                height="{{ 600 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                class="ai-category-card__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-category-card__image-placeholder-{{ ai_gen_id }}">
                {{ 'collection-1' | placeholder_svg_tag }}
              </div>
            {% endif %}

            {% if block.settings.show_overlay %}
              <div class="ai-category-card__overlay-{{ ai_gen_id }}">
                <div class="ai-category-card__content-{{ ai_gen_id }}">
                  <h3 class="ai-category-card__title-{{ ai_gen_id }}">{{ collection.title }}</h3>
                  {% if block.settings.show_product_count %}
                    <div class="ai-category-card__count-{{ ai_gen_id }}">
                      {{ collection.products_count }}
                      {% if collection.products_count == 1 %}
                        Produkt
                      {% else %}
                        Produkte
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</category-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class CategoryGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-category-card-{{ ai_gen_id }}');
        this.setupAccessibility();
      }

      setupAccessibility() {
        this.cards.forEach((card) => {
          card.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              card.click();
            }
          });
        });
      }
    }

    customElements.define('category-grid-{{ ai_gen_id }}', CategoryGrid{{ ai_gen_id }});
  })();
</script>

